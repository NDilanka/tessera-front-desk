{
  // Standalone typecheck for the tsx CLI scripts. They live OUTSIDE the Next.js
  // typecheck scope (the app tsconfig excludes scripts) and use relative `.js`
  // import specifiers + import.meta.url, so they need a Node/ESM-flavoured config.
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": ["node"]
  },
  "include": ["scripts/**/*.ts", "lib/**/*.ts", "data/**/*.json"]
}
