{
  // Standalone typecheck for the tsx CLI scripts. They live OUTSIDE the Next.js
  // typecheck scope (the app tsconfig excludes scripts) and use relative `.js`
  // import specifiers + import.meta.url, so they need a Node/ESM-flavoured config.
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": ["node"]
  },
  // Only the scripts are listed; the lib modules they use are pulled into the
  // program (and type-checked) through the import graph. This deliberately keeps
  // client-only lib files (lib/speech.ts, which touches `window`) OUT of the
  // Node-flavoured scripts program — they are checked by the app tsconfig, which
  // has the DOM lib.
  "include": ["scripts/**/*.ts", "data/**/*.json"]
}
