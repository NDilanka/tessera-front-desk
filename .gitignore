# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (NEVER commit secrets — env.example is the template, no leading dot)
.env
.env.*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local sqlite databases (created by `npm run seed`, eval, and smoke)
/local.db
/local.db-*
/.eval.db
/.eval.db-*
/.smoke.db
/.smoke.db-*
